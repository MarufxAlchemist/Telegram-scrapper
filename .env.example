# Telegram API Credentials
# Get your API credentials from https://my.telegram.org/apps

# Your Telegram API ID (numeric)
TELEGRAM_API_ID=your_api_id_here

# Your Telegram API Hash (alphanumeric string)
TELEGRAM_API_HASH=your_api_hash_here

# Your Telegram account phone number (in international format, e.g., +1234567890)
TELEGRAM_PHONE=+1234567890

# Instructions:
# 1. Copy this file and rename it to .env
# 2. Replace the placeholder values with your actual credentials
# 3. Never commit the .env file to version control
